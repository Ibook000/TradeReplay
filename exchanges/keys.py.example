"""API key settings loaded from environment variables.

Copying this file is no longer required for deployment; exchange adapters read
these variables directly from the environment. Keep this example as a reference
for the expected names.
"""

import os


OKX_API_KEY = os.getenv("OKX_API_KEY", "").strip()
OKX_SECRET_KEY = os.getenv("OKX_SECRET_KEY", "").strip()
OKX_PASSPHRASE = os.getenv("OKX_PASSPHRASE", "").strip()

BYBIT_API_KEY = os.getenv("BYBIT_API_KEY", "").strip()
BYBIT_SECRET_KEY = os.getenv("BYBIT_SECRET_KEY", "").strip()

BITGET_API_KEY = os.getenv("BITGET_API_KEY", "").strip()
BITGET_SECRET_KEY = os.getenv("BITGET_SECRET_KEY", "").strip()
BITGET_PASSPHRASE = os.getenv("BITGET_PASSPHRASE", "").strip()
